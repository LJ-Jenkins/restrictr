f <- \(df, x) {
restrict(
df = validate(
type = data.frame(),
size = 1,
~ ncol(.x) == 1,
\(.x) colnames(.x) == "x"
),
x = cast(type = .env$x, mask = df),
x = coerce(type = integer(), size = df$x, lossy = TRUE)
)
cat("`df$x` casted to ", class(df$x), "from the initial `x` class")
cat("`x` lossily casted to ", class(x), "and recycled using value of `df$x` to", length(x))
}
f(data.frame(x = 3L), 1.5)
